# Self-contained nix-direnv bootstrap: fetches (and caches) nix-direnv so this
# works even though the global direnvrc is devenv-oriented. nix-direnv adds the
# `use flake` helper, which caches the dev shell and reloads it when flake.nix,
# flake.lock, or rust-toolchain.toml change.
if ! has nix_direnv_version || ! nix_direnv_version 3.1.1; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.1.1/direnvrc" "sha256-p+fzQdrms/hDa7g+soShAybJNo4bN4SIAeSfqNKgD5I="
fi

# Reload the shell when the pinned toolchain changes too.
watch_file rust-toolchain.toml

use flake
